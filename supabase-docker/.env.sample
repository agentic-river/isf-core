JWT_KEYS=[{"kty":"EC","kid":"4cf2995c-d4c8-459a-b2c8-9fb297670e0f","use":"sig","key_ops":["sign","verify"],"alg":"ES256","ext":true,"crv":"P-256","x":"8Nu32Y7XKqkYJQxjsxpJUk1d1CWmNtTRZCpnknwYmqI","y":"_v0VjI-pOwgrdgKEMpKa8hzbcqpHd5lfToHe6z2D_WQ","d":"hgi3mhuS4RgRsjhjv9ctpxsv4lL2QEQhzmqo72NJlkg"},{"kty":"oct","k":"dndNeWtGaDg3TkxpdXI5VjBkVGtIcnlKd3orS05nRmpVUHdDblN3Mg","alg":"HS256"}]
