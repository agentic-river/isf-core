# ============================================================
# .env — ISF-Core infrastructure configuration
# ============================================================
# Fill in the keys required by the ISF-Core backend service.
# ============================================================

# tavily.com — web search tool (required for deep research)
TAVILY_API_KEY=

# ISF backend secret key (auto-generated by setup.py on first run)
ISF_SECRET_KEY=

TELEGRAM_BOT_TOKEN_C1=
ALLOWED_TELEGRAM_IDS=

# # Postgres
# POSTGRES_PASSWORD=

# # Legacy symmetric HS256 key
# JWT_SECRET=
# # Legacy API keys (HS256-signed JWTs)
# ANON_KEY=
# SERVICE_ROLE_KEY=

# SUPABASE_URL=http://host.docker.internal:8000