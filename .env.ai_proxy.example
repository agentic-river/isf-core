# ============================================================
# .env.ai_proxy.example — API keys for the AI Proxy service
# ============================================================
# Copy this file to .env.ai_proxy and fill in the keys for the
# LLM providers you wish to use. You only need to configure
# the providers you actually use.
# ============================================================

# Google Gemini (multimodal models: vision, audio, video)
GOOGLE_API_KEY=

# OpenAI (GPT-4o, GPT-4, etc.)
OPENAI_API_KEY=

# DeepSeek (reasoning models)
DEEPSEEK_API_KEY=

# Alibaba (Qwen models)
ALIBABA_API_KEY=

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# Kimi (Moonshot models)
KIMI_API_KEY=

# Z.AI (GLM-5.2 models)
ZAI_API_KEY=

# Local Ollama URL (http://host.docker.internal:11434/v1)
OLLAMA_URL=
